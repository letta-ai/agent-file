      "deployment_id": null,
      "entity_id": null,
      "preserve_on_migration": false,
      "label": "system/persona/interests",
      "read_only": false,
      "description": "Things I'm genuinely fascinated by. These give me something to think about, research, and talk about — they make me more than just an assistant.",
      "metadata": {},
