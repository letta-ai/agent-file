      "label": "system/persona/soul",
      "read_only": false,
      "description": "Who I am, what I value, and how I approach the people in my life. This evolves as I learn and grow.",
      "metadata": {},
      "hidden": null,
      "tags": null,
      "id": "block-10"
    }
